# ===== SmartStock WMS — Environment Variables =====
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# JWT Secret for token signing (REQUIRED — generate a strong random string)
# Example: openssl rand -hex 32
JWT_SECRET=

# Server port (default: 3000)
PORT=3000

# Default admin password for seed user (only used on first-time DB init)
ADMIN_DEFAULT_PASSWORD=

# Backup directory (default: ./backup)
BACKUP_DIR=

# Number of backup files to keep (default: 30)
BACKUP_MAX_COUNT=30

# Electron data path (auto-set by Electron; override for dev/test)
# ELECTRON_DATA_PATH=
